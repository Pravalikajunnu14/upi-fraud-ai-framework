# ──────────────────────────────────────────────────────────────────────────
# UPI Fraud AI Framework — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────
# 
# Copy this file to .env and update the values for your environment.
# NEVER commit .env to version control!
#
# For development: Run with SETUP_MODE=1 to auto-create demo accounts
#   $ SETUP_MODE=1 python app.py
#
# For production: Set FLASK_ENV=production and all secrets via secure config management
#

# ─ Flask & Security ─────────────────────────────────────────────────────
FLASK_ENV=development
DEBUG=False

# REQUIRED: Generate secure keys (use: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secure-random-key-here-change-this
JWT_SECRET_KEY=your-jwt-secure-key-here-change-this

# JWT token expiration in seconds (default: 3600 = 1 hour)
JWT_ACCESS_TOKEN_EXPIRES=3600

# CORS & Frontend Origins (comma-separated, no spaces)
# Development: Allow localhost
# Production: Set to your specific domain(s) only
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# ─ Database ─────────────────────────────────────────────────────────────
DB_PATH=database/upi_fraud.db

# ─ Email Alerts (Gmail SMTP) ────────────────────────────────────────────
# 
# To use Gmail:
#   1. Enable 2-Factor Authentication on your Google account
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Use that 16-character password below (no spaces)
#
# For other SMTP providers, adjust SMTP_HOST and SMTP_PORT accordingly
#
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_PASSWORD=your-app-specific-password
ALERT_EMAIL_TO=alerts@yourcompany.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ─ Setup Mode (WARNING: Use only for first-time setup) ─────────────────
# 
# If SETUP_MODE=1 and database is empty, demo accounts will be created:
#   Username: admin
#   Password: changeme_admin123
#   
#   Username: user
#   Password: changeme_user123
#
# IMPORTANT: Change these passwords immediately after first login!
# Leave unset (or =0) in production to prevent accidental account creation.
#
# SETUP_MODE=1

# ─ Advanced Settings ────────────────────────────────────────────────────
# (Usually not needed; uncomment to customize)

# ML_MODEL_PATH=ml/models/fraud_model.pkl
# ML_FEATURES_PATH=ml/models/feature_columns.pkl
